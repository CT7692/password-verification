using namespace std;

void getInput(string &);
bool checkLength(string);
bool checkUp(string);
bool checkLo(string);
bool checkDigit(string);
bool checkAlpha(string);
bool checkSymbol(string);
bool checkWhiteSpace(string);
void check(string);


int main()
{
	string password;
	
	check(password);

	return 0;
}

void getInput(string & password)
{
	cout << "Enter a password: ";
	getline(cin, password);
}

bool checkLength(string password)
{
	bool stat;
	

		if ((password.length() >= 8 && 21 >= password.length()))
		{
			stat = true;
			return true;
		}
		else
		{
			stat = false;
			cout << "ERROR! Password must be within 8-20 characters." << endl;
			return false;
		}
	
}

bool checkUp(string password)
{
	bool up;
	for (int i = 0; i < password.length(); i++)
	{


		if (isupper(password[i]))
		{
			up = true;
			return true;
		}
	}
		
			up = false;
			cout << "ERROR! Password must contain an uppercase letter." << endl;
			return false;
		
	

	
}

bool checkLo(string password)
{
	bool lo;

	for (int i = 0; i < password.length(); i++)
	{

		if (islower(password[i]))
		{
			lo = true;
			return true;
		}
	}
		
		
			lo = false;
			cout << "ERROR! Password must have a lowercase letter." << endl;
			return false;
		
	
	
}

bool checkDigit(string password)
{
	bool dig;

	for (int i = 0; i < password.length(); i++)
	{

		if (isdigit(password[i]))
		{
			dig = true;
			return true;
		}
	}
		
			dig = false;
			cout << "ERROR! Password must contain a digit." << endl;
			return false;
		
	

	
}

bool checkAlpha(string password)
{
	bool al;

	for (int i = 0; i < password.length(); i++)
	{

		if (isalpha(password[i]))
		{
			al = true;
			return true;
		}

	}
			al = false;
			cout << "ERROR! Password must contain an alphabetical character." << endl;
			return false;
		
	
	
}

bool checkSymbol(string password)
{
	bool sym;

	for (int i = 0; i < password.length(); i++)
	{

		if (ispunct(password[i]))
		{
			sym = true;
			return true;
		}

	}
			sym = false;
			cout << "ERROR! Password must contain a symbol." << endl;
			return false;
		

	
}

bool checkWhiteSpace(string password)
{
	bool noSpa;

	for (int i = 0; i < password.length(); i++)
	{

		if (isspace(password[i]))
		{
			noSpa = false;
			cout << "ERROR! Password cannot contain any spaces." << endl;
			return false;

		}

	}
			noSpa = true;
			return true;
}

void check(string password)
{

	bool len, up, lo, dig, al, sym, noSp;

	getInput(password);

	len = checkLength(password);
	up = checkUp(password);
	lo = checkLo(password);
	dig = checkDigit(password);
	al = checkAlpha(password);
	sym = checkSymbol(password);
	noSp = checkWhiteSpace(password);
	

	while ((len == false) || (up == false) || (lo == false) || (dig == false) || (al == false) || (sym == false) || (noSp == false))
	{
		getInput(password);

		len = checkLength(password);
		up = checkUp(password);
		lo = checkLo(password);
		dig = checkDigit(password);
		al = checkAlpha(password);
		sym = checkSymbol(password);
		noSp = checkWhiteSpace(password);

	}

	cout << "Password saved: " << password << endl;
	

}

